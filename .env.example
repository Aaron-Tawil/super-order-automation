GCP_PROJECT_ID=your-project-id-here
GCP_LOCATION=us-central1
WEB_UI_URL=http://localhost:8501
NEXT_UI_URL=http://localhost:3000
WEB_API_URL=http://localhost:8000
API_SESSION_COOKIE_NAME=soa_web_api_session

# OAuth providers (configure at least one)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Auth policy
# Exact emails and/or domain suffix rules (prefix with @)
ALLOWED_EMAILS=admin@example.com,@example.co.il
COOKIE_SECRET=

# Comma-separated sender emails to auto-mark incoming orders as test
TEST_ORDER_EMAILS=demo@example.com

# Business IDs and Names (Sensitive - moved from code to .env)
# These and the emails below help Gemini ignore the user's own business data on documents
BLACKLIST_IDS=
BLACKLIST_NAMES=
EXCLUDED_EMAILS=
