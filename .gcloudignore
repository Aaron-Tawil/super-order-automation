# Files to ignore during gcloud functions deploy
.git
.gitignore
.venv
.venv*/
.venv-linux/
.venv-win/
venv
__pycache__
*.pyc

# Local secrets & data
.env
.env.*
!.env.example
env.yaml
deploy_env.yaml
env_vars.yaml
.streamlit/secrets.toml
.streamlit/.cookie_secret
token.json
token.pickle
credentials.json
data-excel/
tests-data/

# Dev/test files
test_serverless.py
run_mvp.py
*.log
tests/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.hypothesis/
.cache/
.coverage
.coverage.*
htmlcov/
.pre-commit-config.yaml
uv.lock
pyproject.toml

# Example files (not needed in production)
example/

# Agent & Bot Artifacts
.agent/
.sessions.json

# Documentation
docs/
*.md
!README.md

# Deployment & Utility Scripts (Not needed in runtime)
scripts/
deploy.py
deploy_ui.py
